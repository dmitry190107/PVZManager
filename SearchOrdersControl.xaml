<UserControl x:Class="PVZManagerWPF.SearchOrdersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="txtSearch" Width="200" Height="25" Margin="0,0,10,0"/>
            <Button x:Name="btnSearch" Content="Найти" Width="70" Click="BtnSearch_Click"/>
        </StackPanel>
        <DataGrid x:Name="dgvOrders" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow" MouseDoubleClick="DgvOrders_MouseDoubleClick"/>
    </Grid>
</UserControl>