<UserControl x:Class="PVZManagerWPF.IssueOrderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Номер заказа:" FontWeight="Bold" Margin="0,5"/>
        <TextBlock x:Name="lblOrderNum" Grid.Row="0" Grid.Column="1" Margin="0,5"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Клиент:" FontWeight="Bold" Margin="0,5"/>
        <TextBlock x:Name="lblCustomer" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Телефон:" FontWeight="Bold" Margin="0,5"/>
        <TextBlock x:Name="lblPhone" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус:" FontWeight="Bold" Margin="0,5"/>
        <TextBlock x:Name="lblStatus" Grid.Row="3" Grid.Column="1" Margin="0,5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ячейка:" FontWeight="Bold" Margin="0,5"/>
        <TextBlock x:Name="lblCell" Grid.Row="4" Grid.Column="1" Margin="0,5"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Способ подтверждения:" FontWeight="Bold" Margin="0,5"/>
        <ComboBox x:Name="cboVerification" Grid.Row="5" Grid.Column="1" Margin="0,5">
            <ComboBoxItem Content="паспорт"/>
            <ComboBoxItem Content="код_из_смс"/>
            <ComboBoxItem Content="другое"/>
        </ComboBox>

        <Button x:Name="btnIssue" Grid.Row="6" Grid.ColumnSpan="2" Content="Выдать заказ" Width="120" Height="30" Margin="0,20" HorizontalAlignment="Center" Click="BtnIssue_Click"/>

        <DataGrid x:Name="dgvItems" Grid.Row="7" Grid.ColumnSpan="2" AutoGenerateColumns="True" IsReadOnly="True" Margin="0,10,0,0" Height="200"/>
    </Grid>
</UserControl>